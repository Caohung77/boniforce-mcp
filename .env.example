# Public URL the server is reachable at (must match exactly what Caddy serves).
BF_ISSUER_URL=https://mcp.boniforce.de

# Where SQLite stores users / OAuth state / encrypted Boniforce tokens.
BF_DB_PATH=/var/lib/boniforce-mcp/db.sqlite

# Fernet key (generate with `boniforce-mcp genkey`).
BF_ENCRYPTION_KEY=

# RSA private key in PEM (generate with `boniforce-mcp gensigning`).
# Multi-line: wrap in quotes or escape newlines as \n.
BF_OAUTH_SIGNING_KEY=

# Boniforce API base URL.
BF_API_BASE=https://api.boniforce.de

# uvicorn bind. Keep on localhost; Caddy proxies in front.
BF_HOST=127.0.0.1
BF_PORT=8000

# Audience claim for issued JWTs. Clients don't see this; pick anything stable.
BF_JWT_AUDIENCE=boniforce-mcp
